<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.layout.StackPane?>
<?import jfx.incubator.scene.control.richtext.CodeArea?>
<?import name.ulbricht.dlx.ui.view.editor.EditorViewModel?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:id="editorRoot" fx:controller="name.ulbricht.dlx.ui.view.editor.EditorController">

    <stylesheets>
        <URL value="@EditorView.css"/>
    </stylesheets>

    <fx:define>
        <EditorViewModel fx:id="viewModel"/>
    </fx:define>

    <CodeArea fx:id="sourceCodeArea" lineNumbersEnabled="true"/>

</StackPane>