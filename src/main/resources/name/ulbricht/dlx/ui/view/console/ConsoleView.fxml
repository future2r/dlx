<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import name.ulbricht.dlx.ui.view.console.ConsoleViewModel?>
<?import name.ulbricht.dlx.ui.view.ViewServices?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:id="consoleRoot" fx:controller="name.ulbricht.dlx.ui.view.console.ConsoleController">

    <stylesheets>
        <URL value="@ConsoleView.css"/>
    </stylesheets>

    <fx:define>
        <ViewServices fx:id="console" fx:factory="console"/>
        <ConsoleViewModel fx:id="viewModel">
            <uiExecutor>
                <ViewServices fx:factory="uiExecutor"/>
            </uiExecutor>
            <console>
                <fx:reference source="console"/>
            </console>
        </ConsoleViewModel>
    </fx:define>

    <center>
        <TextArea fx:id="consoleTextArea" editable="false" wrapText="true"/>
    </center>

    <right>

        <ToolBar orientation="vertical">

            <Button onAction="#handleClear">
                <tooltip>
                    <Tooltip text="%console.clear.tooltip"/>
                </tooltip>
                <graphic>
                    <fx:include source="/name/ulbricht/dlx/ui/icon/delete_16_regular.fxml"/>
                </graphic>
            </Button>

        </ToolBar>

    </right>

</BorderPane>